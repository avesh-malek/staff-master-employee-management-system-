PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ems_db
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=1d
CLIENT_ORIGIN=http://localhost:5173
